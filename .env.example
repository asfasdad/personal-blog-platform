# Cloudflare access tokens / environment placeholders
CLOUDFLARE_ACCOUNT_ID=your-account-id
CLOUDFLARE_API_TOKEN=your-api-token
CLOUDFLARE_PAGES_PROJECT=your-pages-project
CLOUDFLARE_PRODUCTION_BRANCH=main
CLOUDFLARE_CUSTOM_DOMAIN=blog.example.com

# Database connection placeholder
DATABASE_URL=postgres://user:pass@localhost:5432/db

# Public site URL used by adapters or previews
PUBLIC_SITE_URL=https://your-domain.example

# Newsletter provider
BUTTONDOWN_API_KEY=your-buttondown-api-key

# Public analytics token (safe for frontend script)
PUBLIC_CLOUDFLARE_WEB_ANALYTICS_TOKEN=your-cloudflare-web-analytics-token

# Admin access and workflow dispatch
ADMIN_ACCESS_KEY=change-this-admin-key
GITHUB_AUTOMATION_TOKEN=your-github-actions-token
GITHUB_REPO_OWNER=your-github-owner
GITHUB_REPO_NAME=your-github-repo
GITHUB_WORKFLOW_PUBLISH=publish.yml
GITHUB_WORKFLOW_ROLLBACK=rollback.yml
GITHUB_WORKFLOW_PAUSE=pause.yml
GITHUB_WORKFLOW_RESUME=resume.yml

# AI drafting pipeline
AI_WRITER_API_KEY=your-ai-writer-api-key

# Giscus comments configuration (optional for local dev)
PUBLIC_GISCUS_REPO=owner/repo
PUBLIC_GISCUS_REPO_ID=
PUBLIC_GISCUS_CATEGORY=Announcements
PUBLIC_GISCUS_CATEGORY_ID=
PUBLIC_GISCUS_MAPPING=pathname
PUBLIC_GISCUS_REACTIONS_ENABLED=1
PUBLIC_GISCUS_EMIT_METADATA=0
PUBLIC_GISCUS_INPUT_POSITION=top
PUBLIC_GISCUS_THEME=light
PUBLIC_GISCUS_LANG=en
