---
import IconX from "@/assets/icons/IconX.svg";
import IconMoon from "@/assets/icons/IconMoon.svg";
import IconSearch from "@/assets/icons/IconSearch.svg";
import IconArchive from "@/assets/icons/IconArchive.svg";
import IconSunHigh from "@/assets/icons/IconSunHigh.svg";
import IconMenuDeep from "@/assets/icons/IconMenuDeep.svg";
import LinkButton from "./LinkButton.astro";
import { SITE } from "@/config";

const { pathname } = Astro.url;

// Remove trailing slash from current pathname if exists
const currentPath =
  pathname.endsWith("/") && pathname !== "/" ? pathname.slice(0, -1) : pathname;

const isActive = (path: string) => {
  const currentPathArray = currentPath.split("/").filter(p => p.trim());
  const pathArray = path.split("/").filter(p => p.trim());

  return currentPath === path || currentPathArray[0] === pathArray[0];
};
---

<a
  id="skip-to-content"
  href="#main-content"
  class="absolute start-10 -top-full z-50 rounded-full bg-surface px-4 py-2 text-accent shadow-sm backdrop-blur-lg transition-all focus:top-4"
>
  <span data-i18n="ui.skipToContent">跳转到内容</span>
</a>

<header
  class="app-layout flex flex-col items-center justify-between py-3 sm:flex-row sm:py-5"
>
  <div
    id="top-nav-wrap"
    class:list={[
      "border border-border",
      "relative w-full rounded-2xl bg-surface px-4 shadow-[var(--shadow-soft)] sm:px-6",
      "flex items-baseline justify-between sm:items-center",
    ]}
  >
    <a
      href="/"
      class="absolute py-1 text-xl leading-8 font-semibold whitespace-nowrap sm:static sm:my-auto sm:text-2xl sm:leading-none"
    >
      {SITE.title}
    </a>
    <nav
      id="nav-menu"
      class="flex w-full flex-col items-center sm:ms-2 sm:min-w-0 sm:flex-row sm:justify-end sm:space-x-4 sm:py-0"
    >
      <button
        id="menu-btn"
        class="focus-outline self-end p-2 sm:hidden"
        aria-label="Open Menu"
        data-i18n-attr="aria-label:nav.openMenu"
        aria-expanded="false"
        aria-controls="menu-items"
      >
        <IconX id="close-icon" class="hidden" />
        <IconMenuDeep id="menu-icon" />
      </button>
      <ul
        id="menu-items"
        class:list={[
          "mt-4 grid w-52 grid-cols-2 place-content-center gap-2",
          "[&>li>a]:block [&>li>a]:rounded-full [&>li>a]:px-4 [&>li>a]:py-2 [&>li>a]:text-center [&>li>a]:font-medium [&>li>a]:hover:bg-surface-strong [&>li>a]:hover:text-accent sm:[&>li>a]:px-3 sm:[&>li>a]:py-1.5",
          "hidden",
          "sm:mt-0 sm:flex sm:w-full sm:flex-wrap sm:justify-end sm:gap-x-4 sm:gap-y-0",
        ]}
      >
        <li class="col-span-2">
          <a href="/blog" class:list={{ "active-nav": isActive("/blog") }}>
            <span data-i18n="nav.blog">博客</span>
          </a>
        </li>
        <li class="col-span-2">
          <a href="/tags" class:list={{ "active-nav": isActive("/tags") }}>
            <span data-i18n="nav.tags">标签</span>
          </a>
        </li>
        <li class="col-span-2">
          <a
            href="/projects"
            class:list={{ "active-nav": isActive("/projects") }}
          >
            <span data-i18n="nav.projects">项目</span>
          </a>
        </li>
        <li class="col-span-2">
          <a href="/about" class:list={{ "active-nav": isActive("/about") }}>
            <span data-i18n="nav.about">关于</span>
          </a>
        </li>
        {
          SITE.showArchives && (
            <li class="col-span-2">
              <LinkButton
                href="/archives"
                class:list={[
                  "focus-outline flex justify-center p-3 sm:p-1",
                  {
                    "active-nav [&>svg]:stroke-accent": isActive("/archives"),
                  },
                ]}
                title="Archives"
                aria-label="archives"
                data-i18n-attr="title:nav.archives,aria-label:nav.archives"
              >
                <IconArchive class="hidden sm:inline-block" />
                <span class="sm:sr-only" data-i18n="nav.archives">归档</span>
              </LinkButton>
            </li>
          )
        }
        <li class="col-span-2 flex items-center justify-center gap-2 sm:col-span-1 sm:justify-end">
          <button
            type="button"
            data-lang-switch="en"
            aria-pressed="true"
            class="rounded-full border border-border px-3 py-1 text-xs ui-label hover:bg-surface-strong"
          >
            EN
          </button>
          <button
            type="button"
            data-lang-switch="zh"
            aria-pressed="false"
            class="rounded-full border border-border px-3 py-1 text-xs ui-label hover:bg-surface-strong"
          >
            中文
          </button>
        </li>
        <li class="col-span-1 flex items-center justify-center">
          <LinkButton
            href="/search"
            class:list={[
              "focus-outline flex p-3 sm:p-1",
              { "[&>svg]:stroke-accent": isActive("/search") },
            ]}
            title="Search"
            aria-label="search"
            data-i18n-attr="title:nav.search,aria-label:nav.search"
          >
            <IconSearch />
            <span class="sr-only" data-i18n="nav.search">搜索</span>
          </LinkButton>
        </li>
        {
          SITE.lightAndDarkMode && (
            <li class="col-span-1 flex items-center justify-center">
              <button
                id="theme-btn"
                class="focus-outline relative size-12 p-4 sm:size-8 hover:[&>svg]:stroke-accent"
                title="Toggles light and dark"
                data-i18n-attr="title:nav.themeToggle"
                aria-label="auto"
                aria-live="polite"
              >
                <IconMoon class="absolute top-[50%] left-[50%] -translate-[50%] scale-100 rotate-0 transition-all dark:scale-0 dark:-rotate-90" />
                <IconSunHigh class="absolute top-[50%] left-[50%] -translate-[50%] scale-0 rotate-90 transition-all dark:scale-100 dark:rotate-0" />
              </button>
            </li>
          )
        }
      </ul>
    </nav>
  </div>
</header>

<script>
  function toggleNav() {
    const menuBtn = document.querySelector("#menu-btn");
    const menuItems = document.querySelector("#menu-items");
    const menuIcon = document.querySelector("#menu-icon");
    const closeIcon = document.querySelector("#close-icon");

    if (!menuBtn || !menuItems || !menuIcon || !closeIcon) return;

    const menuLabel = (open) => {
      const isZh = (document.documentElement.lang || "en").toLowerCase().startsWith("zh");
      if (isZh) return open ? "关闭菜单" : "打开菜单";
      return open ? "Close Menu" : "Open Menu";
    };

    menuBtn.addEventListener("click", () => {
      const openMenu = menuBtn.getAttribute("aria-expanded") === "true";

      menuBtn.setAttribute("aria-expanded", openMenu ? "false" : "true");
      menuBtn.setAttribute("aria-label", menuLabel(openMenu));

      menuItems.classList.toggle("hidden");
      menuIcon.classList.toggle("hidden");
      closeIcon.classList.toggle("hidden");
    });
  }

  toggleNav();

  // Runs on view transitions navigation
  document.addEventListener("astro:after-swap", toggleNav);
</script>
