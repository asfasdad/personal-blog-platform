---
import { type CollectionEntry } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Tag from "@/components/Tag.astro";
import Datetime from "@/components/Datetime.astro";
import EditPost from "@/components/EditPost.astro";
import ShareLinks from "@/components/ShareLinks.astro";
import Comments from "@/components/Comments.astro";
import BackButton from "@/components/BackButton.astro";
import BackToTopButton from "@/components/BackToTopButton.astro";
import { getPath } from "@/utils/getPath";
import { slugifyStr } from "@/utils/slugify";
import IconChevronLeft from "@/assets/icons/IconChevronLeft.svg";
import IconChevronRight from "@/assets/icons/IconChevronRight.svg";
import { SITE } from "@/config";

type Props = {
  post: CollectionEntry<"blog">;
  posts: CollectionEntry<"blog">[];
};

const { post, posts } = Astro.props;

const {
  title,
  author,
  description,
  ogImage: initOgImage,
  canonicalURL,
  pubDatetime,
  modDatetime,
  timezone,
  tags,
  hideEditPost,
} = post.data;

// Use pre-rendered HTML from Content Collection data store.
// Avoids Astro's render() which uses createRequire (broken on CF Workers).
const contentHtml = (post as any).rendered?.html
  ?? await (async () => {
    // Fallback: parse raw markdown body if pre-rendered HTML not available
    const { marked } = await import("marked");
    return marked.parse(post.body ?? "");
  })();

let ogImageUrl: string | undefined;

// Determine OG image source
if (typeof initOgImage === "string") {
  ogImageUrl = initOgImage; // Remote OG image (absolute URL)
} else if (initOgImage?.src) {
  ogImageUrl = initOgImage.src; // Local asset
}

// Use dynamic OG image if enabled and no remote|local ogImage
if (!ogImageUrl && SITE.dynamicOgImage) {
  ogImageUrl = `${getPath(post.id, post.filePath)}/index.png`;
}

// Resolve OG image URL (or fallback to SITE.ogImage / default `og.png`)
const ogImage = ogImageUrl
  ? new URL(ogImageUrl, Astro.url.origin).href
  : undefined;

const layoutProps = {
  title: `${title} | ${SITE.title}`,
  author,
  description,
  pubDatetime,
  modDatetime,
  canonicalURL,
  ogImage,
  scrollSmooth: true,
};

/* ========== Prev/Next Posts ========== */

const allPosts = posts.map(({ data: { title }, id, filePath }) => ({
  id,
  title,
  filePath,
}));

const currentPostIndex = allPosts.findIndex(a => a.id === post.id);

const prevPost = currentPostIndex !== 0 ? allPosts[currentPostIndex - 1] : null;
const nextPost =
  currentPostIndex !== allPosts.length ? allPosts[currentPostIndex + 1] : null;

const currentTags = tags.map(tag => slugifyStr(tag));
const relatedPosts = posts
  .filter(candidate => candidate.id !== post.id)
  .filter(candidate =>
    candidate.data.tags.some(tag => currentTags.includes(slugifyStr(tag)))
  )
  .slice(0, 3);
---

<Layout {...layoutProps}>
  <Header />
  <BackButton />
  <main
    id="main-content"
    class:list={["app-layout pb-12", { "mt-8": !SITE.showBackButton }]}
    data-pagefind-body
  >
    <h1
      transition:name={slugifyStr(title.replaceAll(".", "-"))}
      class="inline-block text-2xl font-bold text-accent sm:text-3xl"
    >
      {title}
    </h1>
    <div class="my-2 flex items-center gap-2">
      <Datetime {pubDatetime} {modDatetime} {timezone} size="lg" />
      <span
        aria-hidden="true"
        class:list={[
          "max-sm:hidden",
          { hidden: !SITE.editPost.enabled || hideEditPost },
        ]}>|</span
      >
      <EditPost {hideEditPost} {post} class="max-sm:hidden" />
    </div>
    <div class="mt-8 grid grid-cols-1 gap-8 lg:grid-cols-[16rem_minmax(0,1fr)] xl:grid-cols-[16rem_minmax(0,1fr)_16rem]">
      <!-- TOC sidebar -->
      <aside
        id="toc-sidebar"
        class="hidden lg:block"
        aria-labelledby="toc-title"
        data-pagefind-ignore
      >
        <div class="sticky top-24 max-h-[calc(100vh-7rem)] overflow-y-auto">
          <div class="rounded-xl border border-border bg-surface p-4 shadow-[var(--shadow-soft)]">
            <h2 id="toc-title" class="flex items-center justify-between text-lg font-semibold">
              <span>目录</span>
              <button
                id="toc-toggle-all"
                class="text-xs text-foreground/60 hover:text-accent"
                aria-label="折叠目录"
              >
                折叠
              </button>
            </h2>
            <nav id="post-toc" class="mt-3">
              <p id="post-toc-empty" class="text-sm text-foreground/80">
                标题链接将在此处显示。
              </p>
              <ul id="post-toc-list" class="space-y-1 text-sm"></ul>
            </nav>
          </div>
        </div>
      </aside>

      <article
        id="article"
        class="app-prose w-full max-w-app prose-pre:bg-(--shiki-light-bg) dark:prose-pre:bg-(--shiki-dark-bg)"
        set:html={contentHtml}
      />
    </div>

    <hr class="my-8 border-dashed" />

    <EditPost class="sm:hidden" {hideEditPost} {post} />

    <ul class="mt-4 mb-8 flex flex-wrap gap-4 sm:my-8">
      {tags.map(tag => <Tag tag={slugifyStr(tag)} tagName={tag} size="sm" />)}
    </ul>

    <BackToTopButton />

    <ShareLinks />

    <hr class="my-6 border-dashed" />

    <section data-pagefind-ignore>
      <h2 class="text-xl font-semibold">相关文章</h2>
      {
        relatedPosts.length > 0 ? (
          <ul class="mt-4 space-y-2">
            {relatedPosts.map(related => (
              <li>
                <a
                  href={getPath(related.id, related.filePath)}
                  class="text-accent underline-offset-4 hover:underline"
                >
                  {related.data.title}
                </a>
              </li>
            ))}
          </ul>
        ) : (
          <p class="mt-3 text-foreground/80">更多相关文章会随着内容积累而显示。</p>
        )
      }
    </section>

    <hr class="my-6 border-dashed" />

    <Comments />

    <hr class="my-6 border-dashed" />

    <!-- Previous/Next Post Buttons -->
    <div data-pagefind-ignore class="grid grid-cols-1 gap-6 sm:grid-cols-2">
      {
        prevPost && (
          <a
            href={getPath(prevPost.id, prevPost.filePath)}
            class="flex w-full gap-1 hover:opacity-75"
          >
            <IconChevronLeft class="inline-block flex-none rtl:rotate-180" />
            <div>
              <span>上一篇</span>
              <div class="text-sm text-accent/85">{prevPost.title}</div>
            </div>
          </a>
        )
      }
      {
        nextPost && (
          <a
            href={getPath(nextPost.id, nextPost.filePath)}
            class="flex w-full justify-end gap-1 text-end hover:opacity-75 sm:col-start-2"
          >
            <div>
              <span>下一篇</span>
              <div class="text-sm text-accent/85">{nextPost.title}</div>
            </div>
            <IconChevronRight class="inline-block flex-none rtl:rotate-180" />
          </a>
        )
      }
    </div>
  </main>
  <Footer />
</Layout>

<script is:inline data-astro-rerun>
  /** Create a progress indicator
   *  at the top */
  function createProgressBar() {
    // Create the main container div
    const progressContainer = document.createElement("div");
    progressContainer.className =
      "progress-container fixed top-0 z-10 h-1 w-full bg-background";

    // Create the progress bar div
    const progressBar = document.createElement("div");
    progressBar.className = "progress-bar h-1 w-0 bg-accent";
    progressBar.id = "myBar";

    // Append the progress bar to the progress container
    progressContainer.appendChild(progressBar);

    // Append the progress container to the document body or any other desired parent element
    document.body.appendChild(progressContainer);
  }
  createProgressBar();

  /** Update the progress bar
   *  when user scrolls */
  function updateScrollProgress() {
    document.addEventListener("scroll", () => {
      const winScroll =
        document.body.scrollTop || document.documentElement.scrollTop;
      const height =
        document.documentElement.scrollHeight -
        document.documentElement.clientHeight;
      const scrolled = (winScroll / height) * 100;
      if (document) {
        const myBar = document.getElementById("myBar");
        if (myBar) {
          myBar.style.width = scrolled + "%";
        }
      }
    });
  }
  updateScrollProgress();

  function buildTableOfContents() {
    const tocList = document.querySelector("#post-toc-list");
    const tocEmpty = document.querySelector("#post-toc-empty");
    const toggleAllBtn = document.querySelector("#toc-toggle-all");
    const headings = Array.from(
      document.querySelectorAll("#article h2, #article h3, #article h4")
    );

    if (!(tocList instanceof HTMLUListElement) || headings.length === 0) return;

    tocList.innerHTML = "";

    // Build tree: h2 -> [h3 -> [h4]]
    const h2List = [];
    let currentH2 = null;
    let currentH3 = null;

    for (const h of headings) {
      const level = h.tagName;
      if (level === "H2") {
        currentH2 = { el: h, h3s: [] };
        h2List.push(currentH2);
        currentH3 = null;
      } else if (level === "H3") {
        if (currentH2) {
          currentH3 = { el: h, h4s: [] };
          currentH2.h3s.push(currentH3);
        }
      } else if (level === "H4") {
        if (currentH3) {
          currentH3.h4s.push(h);
        } else if (currentH2) {
          currentH3 = { el: h as any, h4s: [] };
          currentH2.h3s.push(currentH3);
          currentH3 = null;
        }
      }
    }

    // Render tree
    function makeLink(el) {
      if (!el.id) return null;
      const a = document.createElement("a");
      a.href = `#${el.id}`;
      a.textContent = el.textContent ?? "";
      return a;
    }

    function renderEntry(h2Entry) {
      const li = document.createElement("li");
      const a = makeLink(h2Entry.el);
      if (!a) return li;

      a.className = "block py-1 pr-2 text-accent hover:underline leading-snug";
      li.appendChild(a);

      if (h2Entry.h3s.length > 0) {
        const arrow = document.createElement("span");
        arrow.className = "me-1 text-foreground/40 inline-block chevron";
        arrow.textContent = "▾";
        a.insertBefore(arrow, a.firstChild);
        a.classList.add("toc-parent", "cursor-pointer");

        const subUl = document.createElement("ul");
        subUl.className = "ms-3 border-s border-border pl-3 mt-1 space-y-1";

        for (const h3Entry of h2Entry.h3s) {
          const h3Li = document.createElement("li");
          const h3A = makeLink(h3Entry.el);
          if (!h3A) continue;

          h3A.className = "block py-0.5 pr-2 text-foreground/80 hover:text-accent text-xs leading-snug";
          h3Li.appendChild(h3A);

          if (h3Entry.h4s.length > 0) {
            const h3Arrow = document.createElement("span");
            h3Arrow.className = "me-1 text-foreground/30 inline-block chevron";
            h3Arrow.textContent = "▾";
            h3A.insertBefore(h3Arrow, h3A.firstChild);
            h3A.classList.add("toc-parent", "cursor-pointer");

            const h4Ul = document.createElement("ul");
            h4Ul.className = "ms-3 border-s border-border pl-3 mt-0.5 space-y-0.5";

            for (const h4 of h3Entry.h4s) {
              if (!h4.id) continue;
              const h4Li = document.createElement("li");
              const h4A = document.createElement("a");
              h4A.href = `#${h4.id}`;
              h4A.textContent = h4.textContent ?? "";
              h4A.className = "block py-0.5 pr-2 text-foreground/60 hover:text-accent text-xs leading-snug";
              h4Li.appendChild(h4A);
              h4Ul.appendChild(h4Li);
            }
            h3Li.appendChild(h4Ul);
          }

          subUl.appendChild(h3Li);
        }

        li.appendChild(subUl);
      }

      return li;
    }

    for (const entry of h2List) {
      const li = renderEntry(entry);
      tocList.appendChild(li);
    }

    if (tocEmpty instanceof HTMLElement) {
      tocEmpty.classList.toggle("hidden", tocList.childElementCount > 0);
    }

    // Collapse: click parent to toggle sub-list
    tocList.querySelectorAll(".toc-parent").forEach(parent => {
      parent.addEventListener("click", e => {
        const next = parent.nextElementSibling;
        if (next && next.tagName === "UL") {
          e.preventDefault();
          next.classList.toggle("hidden");
          const chevron = parent.querySelector(".chevron");
          if (chevron) chevron.textContent = next.classList.contains("hidden") ? "▸" : "▾";
        }
      });
    });

    // Toggle all
    if (toggleAllBtn instanceof HTMLElement) {
      toggleAllBtn.addEventListener("click", () => {
        const subs = tocList.querySelectorAll(":scope > li > ul");
        const allHidden = Array.from(subs).every(s => s.classList.contains("hidden"));
        subs.forEach(s => {
          s.classList.toggle("hidden", !allHidden);
          const chevron = s.previousElementSibling?.querySelector(".chevron");
          if (chevron) chevron.textContent = allHidden ? "▾" : "▸";
        });
        toggleAllBtn.textContent = allHidden ? "展开" : "折叠";
      });
    }

    // Highlight active heading on scroll
    const observer = new IntersectionObserver(
      entries => {
        entries.forEach(entry => {
          const id = entry.target.id;
          if (!id) return;
          const link = tocList.querySelector(`a[href="#${id}"]`);
          if (entry.isIntersecting) {
            tocList.querySelectorAll("a").forEach(a => {
              a.classList.remove("text-accent", "font-semibold");
              a.classList.add("text-foreground/80");
            });
            if (link) {
              link.classList.remove("text-foreground/80");
              link.classList.add("text-accent", "font-semibold");
            }
          }
        });
      },
      { rootMargin: "-15% 0px -75% 0px" }
    );

    headings.forEach(h => { if (h.id) observer.observe(h); });
  }
  buildTableOfContents();

  /** Attaches links to headings in the document,
   *  allowing sharing of sections easily */
  function addHeadingLinks() {
    const headings = Array.from(
      document.querySelectorAll("h2, h3, h4, h5, h6")
    );
    for (const heading of headings) {
      heading.classList.add("group");
      const link = document.createElement("a");
      link.className =
        "heading-link ms-2 no-underline opacity-75 md:opacity-0 md:group-hover:opacity-100 md:focus:opacity-100";
      link.href = "#" + heading.id;

      const span = document.createElement("span");
      span.ariaHidden = "true";
      span.innerText = "#";
      link.appendChild(span);
      heading.appendChild(link);
    }
  }
  addHeadingLinks();

  /** Attaches copy buttons to code blocks in the document,
   * allowing users to copy code easily. */
  function attachCopyButtons() {
    const copyButtonLabel = "Copy";
    const codeBlocks = Array.from(document.querySelectorAll("pre"));

    for (const codeBlock of codeBlocks) {
      const wrapper = document.createElement("div");
      wrapper.style.position = "relative";

      // Check if --file-name-offset custom property exists
      const computedStyle = getComputedStyle(codeBlock);
      const hasFileNameOffset =
        computedStyle.getPropertyValue("--file-name-offset").trim() !== "";

      // Determine the top positioning class
      const topClass = hasFileNameOffset
        ? "top-(--file-name-offset)"
        : "-top-3";

      const copyButton = document.createElement("button");
      copyButton.className = `copy-code absolute end-3 ${topClass} rounded bg-muted border border-muted px-2 py-1 text-xs leading-4 text-foreground font-medium`;
      copyButton.innerHTML = copyButtonLabel;
      codeBlock.setAttribute("tabindex", "0");
      codeBlock.appendChild(copyButton);

      // wrap codebock with relative parent element
      codeBlock?.parentNode?.insertBefore(wrapper, codeBlock);
      wrapper.appendChild(codeBlock);

      copyButton.addEventListener("click", async () => {
        await copyCode(codeBlock, copyButton);
      });
    }

    async function copyCode(block, button) {
      const code = block.querySelector("code");
      const text = code?.innerText;

      await navigator.clipboard.writeText(text ?? "");

      // visual feedback that task is completed
      button.innerText = "Copied";

      setTimeout(() => {
        button.innerText = copyButtonLabel;
      }, 700);
    }
  }
  attachCopyButtons();

  /* Go to page start after page swap */
  document.addEventListener("astro:after-swap", () =>
    window.scrollTo({ left: 0, top: 0, behavior: "instant" })
  );
</script>
