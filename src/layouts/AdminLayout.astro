---
import { SITE } from "@/config";
import "@/styles/global.css";

export interface Props {
  title: string;
}

const { title } = Astro.props;
const currentPath = Astro.url.pathname;

// Check if user is logged in
const adminAccess = Astro.cookies.get("admin_access")?.value;
if (!adminAccess && Astro.url.pathname !== "/admin/login") {
  return Astro.redirect("/admin/login");
}

// Navigation items (server-rendered, no React dependency)
const navItems = [
  { title: "仪表盘", titleEn: "Dashboard", href: "/admin", icon: "dashboard" },
  {
    title: "文章", titleEn: "Posts", href: "/admin/posts", icon: "file-text",
    children: [
      { title: "所有文章", titleEn: "All Posts", href: "/admin/posts", icon: "list" },
      { title: "新建文章", titleEn: "New Post", href: "/admin/posts/new", icon: "plus" },
    ],
  },
  { title: "媒体库", titleEn: "Media", href: "/admin/media", icon: "image" },
  { title: "标签", titleEn: "Tags", href: "/admin/tags", icon: "tag" },
  { title: "设置", titleEn: "Settings", href: "/admin/settings", icon: "settings" },
];

function isActive(href: string): boolean {
  if (href === "/admin") return currentPath === "/admin" || currentPath === "/admin/";
  return currentPath.startsWith(href);
}
---

<!doctype html>
<html lang="zh-CN" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="robots" content="noindex, nofollow" />
    <title>{title} | {SITE.title} 管理后台</title>
  </head>
  <body class="bg-background text-foreground antialiased">
    <div class="flex h-screen overflow-hidden">
      <!-- Sidebar -->
      <aside
        id="admin-sidebar"
        class="fixed left-0 top-0 z-40 h-screen w-64 -translate-x-full border-r border-border bg-surface transition-transform duration-300 lg:static lg:translate-x-0"
      >
        <div class="flex h-full flex-col">
          <!-- Logo -->
          <div class="flex h-16 items-center border-b border-border px-6">
            <a href="/admin" class="flex items-center gap-2 text-lg font-semibold">
              <span class="text-accent">Admin</span>
              <span class="text-foreground/60">Panel</span>
            </a>
          </div>

          <!-- Navigation -->
          <nav class="flex-1 overflow-y-auto px-4 py-4">
            <ul class="space-y-1">
              {navItems.map(item => (
                <li>
                  <a
                    href={item.href}
                    class:list={[
                      "flex items-center gap-3 rounded-lg px-3 py-2 text-sm font-medium transition-colors",
                      isActive(item.href) && !item.children
                        ? "bg-accent/10 text-accent"
                        : "text-foreground/70 hover:bg-muted hover:text-foreground",
                    ]}
                  >
                    <span class="admin-icon" data-icon={item.icon}></span>
                    {item.title}
                  </a>
                  {item.children && (
                    <ul class="ml-6 mt-1 space-y-1">
                      {item.children.map(child => (
                        <li>
                          <a
                            href={child.href}
                            class:list={[
                              "flex items-center gap-3 rounded-lg px-3 py-2 text-sm transition-colors",
                              isActive(child.href) && currentPath === child.href
                                ? "bg-accent/10 text-accent"
                                : "text-foreground/60 hover:bg-muted hover:text-foreground",
                            ]}
                          >
                            <span class="admin-icon" data-icon={child.icon}></span>
                            {child.title}
                          </a>
                        </li>
                      ))}
                    </ul>
                  )}
                </li>
              ))}
            </ul>
          </nav>

          <!-- Bottom: view site -->
          <div class="border-t border-border p-4">
            <a href="/" target="_blank" class="flex items-center gap-2 text-sm text-foreground/60 hover:text-foreground">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
              访问网站
            </a>
          </div>
        </div>
      </aside>

      <!-- Mobile Sidebar Toggle -->
      <button
        id="sidebar-toggle"
        class="fixed left-4 top-4 z-50 rounded-lg border border-border bg-surface p-2 lg:hidden"
        aria-label="Toggle sidebar"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="3" y1="12" x2="21" y2="12"></line>
          <line x1="3" y1="6" x2="21" y2="6"></line>
          <line x1="3" y1="18" x2="21" y2="18"></line>
        </svg>
      </button>

      <!-- Overlay for mobile -->
      <div id="sidebar-overlay" class="fixed inset-0 z-30 hidden bg-black/50 lg:hidden"></div>

      <!-- Main Content -->
      <main class="flex flex-1 flex-col overflow-hidden">
        <!-- Top Header -->
        <header class="flex h-16 items-center justify-between border-b border-border bg-surface px-6">
          <h1 class="text-xl font-semibold">{title}</h1>
          <div class="flex items-center gap-4">
            <form method="post" action="/api/admin/logout">
              <button
                type="submit"
                class="rounded-lg border border-border px-4 py-2 text-sm hover:bg-muted"
              >
                退出登录
              </button>
            </form>
          </div>
        </header>

        <!-- Page Content -->
        <div class="flex-1 overflow-auto p-6">
          <slot />
        </div>
      </main>
    </div>

    <script>
      // Sidebar toggle
      const sidebar = document.getElementById("admin-sidebar");
      const toggle = document.getElementById("sidebar-toggle");
      const overlay = document.getElementById("sidebar-overlay");

      toggle?.addEventListener("click", () => {
        sidebar?.classList.toggle("-translate-x-full");
        overlay?.classList.toggle("hidden");
      });

      overlay?.addEventListener("click", () => {
        sidebar?.classList.add("-translate-x-full");
        overlay?.classList.add("hidden");
      });

      // Render SVG icons
      const icons: Record<string, string> = {
        dashboard: '<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>',
        "file-text": '<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>',
        list: '<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="8" y1="6" x2="21" y2="6"/><line x1="8" y1="12" x2="21" y2="12"/><line x1="8" y1="18" x2="21" y2="18"/><line x1="3" y1="6" x2="3.01" y2="6"/><line x1="3" y1="12" x2="3.01" y2="12"/><line x1="3" y1="18" x2="3.01" y2="18"/></svg>',
        plus: '<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>',
        image: '<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>',
        tag: '<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"/><line x1="7" y1="7" x2="7.01" y2="7"/></svg>',
        settings: '<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>',
      };

      document.querySelectorAll('.admin-icon').forEach(el => {
        const iconName = (el as HTMLElement).dataset.icon;
        if (iconName && icons[iconName]) {
          el.innerHTML = icons[iconName];
        }
      });
    </script>
    <script is:inline>
      (() => {
        const dict = {
          en: {
            "admin.pageTitle": "Admin",
            "admin.logout": "Logout",
            "admin.posts": "Posts",
            "admin.newPost": "New Post",
            "admin.mediaLibrary": "Media Library",
            "admin.settings": "Settings",
            "admin.upload": "Upload",
            "admin.noMedia": "No media files yet",
            "admin.uploadFirst": "Upload your first image",
            "admin.postTitle": "Post Title",
            "admin.postSlug": "Post Slug",
            "admin.postDescription": "Post Description",
            "admin.postTags": "Tags",
            "admin.postContent": "Content",
            "admin.siteSettings": "Site Settings",
            "admin.authorSettings": "Author Settings",
            "admin.features": "Features",
            "admin.integrations": "Integrations",
            "admin.nav.posts": "Posts",
            "admin.nav.media": "Media",
            "admin.nav.settings": "Settings",
          },
          zh: {
            "admin.pageTitle": "管理后台",
            "admin.logout": "退出登录",
            "admin.posts": "文章管理",
            "admin.newPost": "新建文章",
            "admin.mediaLibrary": "媒体库",
            "admin.settings": "设置",
            "admin.upload": "上传",
            "admin.noMedia": "暂无媒体文件",
            "admin.uploadFirst": "上传第一张图片",
            "admin.postTitle": "文章标题",
            "admin.postSlug": "文章别名",
            "admin.postDescription": "文章描述",
            "admin.postTags": "标签",
            "admin.postContent": "正文",
            "admin.siteSettings": "站点设置",
            "admin.authorSettings": "作者设置",
            "admin.features": "功能开关",
            "admin.integrations": "第三方集成",
            "admin.nav.posts": "文章",
            "admin.nav.media": "媒体",
            "admin.nav.settings": "设置",
          },
        };

        const LANG_KEY = "site-lang";
        const normalizeLang = (value) => (String(value || "").toLowerCase().startsWith("zh") ? "zh" : "en");

        const applyLang = (lang) => {
          document.documentElement.lang = lang === "zh" ? "zh-CN" : "en";
          document.querySelectorAll("[data-i18n]").forEach((node) => {
            const key = node.getAttribute("data-i18n");
            if (!key) return;
            const text = dict[lang]?.[key] ?? dict.en[key];
            if (text) node.textContent = text;
          });
          document.querySelectorAll("[data-lang-switch]").forEach((btn) => {
            const target = normalizeLang(btn.getAttribute("data-lang-switch"));
            btn.setAttribute("aria-pressed", target === lang ? "true" : "false");
          });
        };

        const setLang = (lang) => {
          localStorage.setItem(LANG_KEY, lang);
          applyLang(lang);
        };

        const initLang = () => {
          const saved = normalizeLang(localStorage.getItem(LANG_KEY));
          applyLang(saved);
          document.querySelectorAll("[data-lang-switch]").forEach((btn) => {
            btn.addEventListener("click", () => {
              const target = normalizeLang(btn.getAttribute("data-lang-switch"));
              setLang(target);
            });
          });
        };

        if (document.readyState === "loading") {
          document.addEventListener("DOMContentLoaded", initLang, { once: true });
        } else {
          initLang();
        }
      })();
    </script>
  </body>
</html>
