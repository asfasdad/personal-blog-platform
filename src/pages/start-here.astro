---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import { SITE } from "@/config";

export const prerender = true;
---

<Layout title={`Start Here | ${SITE.title}`}>
  <Header />
  <main id="main-content" class="app-layout">
    <section class="rounded-2xl border border-border bg-surface px-6 py-8 shadow-[var(--shadow-soft)]">
      <h1 class="text-2xl font-semibold sm:text-3xl">Start Here / 新手指南</h1>
      <p class="mt-3 text-foreground/80">
        EN: This page helps first-time users write, preview, and publish posts.
        <br />
        中文：这个页面帮助你第一次完成写作、预览和发布博客。
      </p>
    </section>

    <section class="mt-6 rounded-2xl border border-border bg-surface px-6 py-8 shadow-[var(--shadow-soft)]">
      <h2 class="text-xl font-semibold">1) Write a post / 写文章</h2>
      <p class="mt-3">
        EN: Fastest way: use the scaffold command below.
        <br />
        中文：最快方式：先执行下面的一键模板命令。
      </p>
      <pre class="mt-3 overflow-x-auto rounded-lg border border-border bg-background p-3 text-sm"><code>pnpm new:post --title "My first post"</code></pre>
      <p class="mt-3">
        EN: Add a Markdown file to <code>src/content/blog/</code>.
        <br />
        中文：在 <code>src/content/blog/</code> 新建一个 Markdown 文件。
      </p>
      <pre class="mt-3 overflow-x-auto rounded-lg border border-border bg-background p-3 text-sm"><code>---
title: "My first post"
description: "A quick intro"
pubDatetime: 2026-03-15T10:00:00.000Z
tags: ["welcome"]
---

Hello world.</code></pre>
    </section>

    <section class="mt-6 rounded-2xl border border-border bg-surface px-6 py-8 shadow-[var(--shadow-soft)]">
      <h2 class="text-xl font-semibold">2) Preview locally / 本地预览</h2>
      <pre class="mt-3 overflow-x-auto rounded-lg border border-border bg-background p-3 text-sm"><code>pnpm install
pnpm dev</code></pre>
      <p class="mt-3">
        EN: Open <code>http://127.0.0.1:4321</code> and check your post page.
        <br />
        中文：打开 <code>http://127.0.0.1:4321</code>，检查文章页面效果。
      </p>
    </section>

    <section class="mt-6 rounded-2xl border border-border bg-surface px-6 py-8 shadow-[var(--shadow-soft)]">
      <h2 class="text-xl font-semibold">3) Publish / 发布上线</h2>
      <pre class="mt-3 overflow-x-auto rounded-lg border border-border bg-background p-3 text-sm"><code>git add .
git commit -m "add: my first post"
git push origin main</code></pre>
      <p class="mt-3">
        EN: After push, your deployment pipeline (or manual Wrangler deploy) publishes the update.
        <br />
        中文：推送后，部署流程（或手动 Wrangler 部署）会把更新发布到线上。
      </p>
    </section>

    <section class="mt-6 rounded-2xl border border-border bg-surface px-6 py-8 shadow-[var(--shadow-soft)]">
      <h2 class="text-xl font-semibold">4) Admin login / 管理后台登录</h2>
      <p class="mt-3">
        EN: Visit <code>/admin/login</code> and use your <code>ADMIN_ACCESS_KEY</code>.
        <br />
        中文：访问 <code>/admin/login</code>，使用环境变量 <code>ADMIN_ACCESS_KEY</code> 登录。
      </p>
    </section>
  </main>
  <Footer />
</Layout>
