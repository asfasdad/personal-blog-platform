---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Socials from "@/components/Socials.astro";
import LinkButton from "@/components/LinkButton.astro";
import NewsletterSignup from "@/components/NewsletterSignup.astro";
import IconRss from "@/assets/icons/IconRss.svg";
import IconArrowRight from "@/assets/icons/IconArrowRight.svg";
import { SITE } from "@/config";
import { SOCIALS } from "@/constants";

export const prerender = true;
---

<Layout>
  <Header />
  <main id="main-content" data-layout="index" class="app-layout">
    <section
      id="hero"
      class:list={[
        "rounded-2xl border border-border bg-surface px-6 py-8 shadow-[var(--shadow-soft)]",
      ]}
    >
      <h1 class="my-4 inline-block text-4xl font-bold sm:my-8 sm:text-5xl">
        <span data-i18n="home.heroTitle">Essays, Projects, and Field Notes</span>
      </h1>
      <a
        target="_blank"
        href="/rss.xml"
        class="inline-block"
        aria-label="rss feed"
        title="RSS Feed"
      >
        <IconRss
          width={20}
          height={20}
          class="scale-125 stroke-accent stroke-3 rtl:-rotate-90"
        />
        <span class="sr-only">RSS Feed</span>
      </a>

      <p class="max-w-2xl text-lg">
        <span data-i18n="home.heroDesc">A focused publishing space for long-form engineering writing, build logs, and curated project updates.</span>
      </p>
      {
        // only display if at least one social link is enabled
        SOCIALS.length > 0 && (
          <div class="mt-4 flex max-sm:flex-col sm:items-center">
            <div class="me-2 mb-1 whitespace-nowrap sm:mb-0" data-i18n="home.social">Social Links:</div>
            <Socials />
          </div>
        )
      }
    </section>

    <section
      id="featured"
      class:list={[
        "mt-8 rounded-2xl border border-border bg-surface px-6 py-8 shadow-[var(--shadow-soft)]",
      ]}
    >
      <h2 class="text-2xl font-semibold tracking-wide" data-i18n="home.featured">Featured</h2>
      <p class="mt-3 opacity-85" data-i18n="home.featuredDesc">Read the launch post for this production setup.</p>
      <a href="/blog/hello-world/" class="mt-4 inline-block text-accent underline">
        Hello World
      </a>
    </section>

    <div class="my-8 text-center">
      <LinkButton href="/blog/">
        <span data-i18n="home.allArticles">All Articles</span>
        <IconArrowRight class="inline-block rtl:-rotate-180" />
      </LinkButton>
      <div class="mt-4">
        <a href="/start-here/" class="text-accent underline" data-i18n="home.firstTimeGuide">First-Time Guide</a>
      </div>
    </div>

    <NewsletterSignup />
  </main>
  <Footer />
</Layout>

<script>
  document.addEventListener("astro:page-load", () => {
    const indexLayout = (document.querySelector("#main-content") as HTMLElement)
      ?.dataset?.layout;
    if (indexLayout) {
      sessionStorage.setItem("backUrl", "/");
    }
  });
</script>
