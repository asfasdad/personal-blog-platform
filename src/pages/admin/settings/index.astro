---
import Layout from "@/layouts/AdminLayout.astro";
import { SITE } from "@/config";
import { getD1, SettingsRepo } from "@/db";

// Load saved settings from D1
const db = getD1(Astro.locals);
let savedSettings: Record<string, string> = {};
if (db) {
  try {
    const all = await SettingsRepo.getAll(db);
    for (const s of all) {
      savedSettings[s.key] = s.value;
    }
  } catch { /* D1 not available */ }
}

// Merge with defaults from SITE config
const siteTitle = savedSettings.siteTitle ?? SITE.title;
const siteDescription = savedSettings.siteDescription ?? SITE.desc;
const authorName = savedSettings.authorName ?? SITE.author;
const authorBio = savedSettings.authorBio ?? "";
const githubUrl = savedSettings.githubUrl ?? "";
const twitterUrl = savedSettings.twitterUrl ?? "";
const enableComments = savedSettings.enableComments !== "false";
const enableRss = savedSettings.enableRss !== "false";
const enableSearch = savedSettings.enableSearch !== "false";
const enableNewsletter = savedSettings.enableNewsletter === "true";
---

<Layout title="设置">
  <div class="mx-auto max-w-2xl">
    <h1 class="mb-6 text-2xl font-semibold">站点设置</h1>

    <form id="settings-form" class="space-y-8">
      <!-- Site Settings -->
      <section class="rounded-xl border border-border bg-surface p-6">
        <h2 class="mb-4 text-lg font-semibold">基本信息</h2>
        <div class="space-y-4">
          <div>
            <label class="mb-2 block text-sm font-medium">站点标题</label>
            <input type="text" name="siteTitle" value={siteTitle}
              class="w-full rounded-lg border border-border bg-background px-4 py-2 focus:border-accent focus:outline-none" />
          </div>
          <div>
            <label class="mb-2 block text-sm font-medium">站点描述</label>
            <textarea name="siteDescription" rows="3"
              class="w-full rounded-lg border border-border bg-background px-4 py-2 focus:border-accent focus:outline-none">{siteDescription}</textarea>
          </div>
        </div>
      </section>

      <!-- Author Settings -->
      <section class="rounded-xl border border-border bg-surface p-6">
        <h2 class="mb-4 text-lg font-semibold">作者信息</h2>
        <div class="space-y-4">
          <div>
            <label class="mb-2 block text-sm font-medium">作者名称</label>
            <input type="text" name="authorName" value={authorName}
              class="w-full rounded-lg border border-border bg-background px-4 py-2 focus:border-accent focus:outline-none" />
          </div>
          <div>
            <label class="mb-2 block text-sm font-medium">作者简介</label>
            <textarea name="authorBio" rows="3" placeholder="简要的个人介绍..."
              class="w-full rounded-lg border border-border bg-background px-4 py-2 focus:border-accent focus:outline-none">{authorBio}</textarea>
          </div>
          <div>
            <label class="mb-2 block text-sm font-medium">社交链接</label>
            <div class="space-y-2">
              <input type="url" name="githubUrl" placeholder="GitHub URL" value={githubUrl}
                class="w-full rounded-lg border border-border bg-background px-4 py-2 focus:border-accent focus:outline-none" />
              <input type="url" name="twitterUrl" placeholder="Twitter/X URL" value={twitterUrl}
                class="w-full rounded-lg border border-border bg-background px-4 py-2 focus:border-accent focus:outline-none" />
            </div>
          </div>
        </div>
      </section>

      <!-- Feature Toggles -->
      <section class="rounded-xl border border-border bg-surface p-6">
        <h2 class="mb-4 text-lg font-semibold">功能开关</h2>
        <div class="space-y-3">
          <label class="flex items-center justify-between">
            <span class="text-sm font-medium">启用评论</span>
            <input type="checkbox" name="enableComments" value="true" class="h-5 w-5 rounded border-border" checked={enableComments} />
          </label>
          <label class="flex items-center justify-between">
            <span class="text-sm font-medium">启用 RSS</span>
            <input type="checkbox" name="enableRss" value="true" class="h-5 w-5 rounded border-border" checked={enableRss} />
          </label>
          <label class="flex items-center justify-between">
            <span class="text-sm font-medium">启用搜索</span>
            <input type="checkbox" name="enableSearch" value="true" class="h-5 w-5 rounded border-border" checked={enableSearch} />
          </label>
          <label class="flex items-center justify-between">
            <span class="text-sm font-medium">启用 Newsletter</span>
            <input type="checkbox" name="enableNewsletter" value="true" class="h-5 w-5 rounded border-border" checked={enableNewsletter} />
          </label>
        </div>
      </section>

      <!-- Save Button -->
      <div class="flex gap-3">
        <button type="submit" class="rounded-lg bg-accent px-6 py-2 font-medium text-white hover:bg-accent/90">
          保存设置
        </button>
        <button type="reset" class="rounded-lg border border-border bg-background px-6 py-2 font-medium hover:bg-muted">
          重置
        </button>
      </div>

      <div id="save-status" class="text-sm text-foreground/60"></div>
    </form>
  </div>

  <script>
    const form = document.getElementById('settings-form') as HTMLFormElement;
    const saveStatus = document.getElementById('save-status');

    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const formData = new FormData(form);

      // Handle checkboxes properly
      const data: Record<string, string> = {};
      for (const [key, value] of formData.entries()) {
        data[key] = String(value);
      }
      // Checkboxes that are unchecked don't appear in FormData
      for (const name of ['enableComments', 'enableRss', 'enableSearch', 'enableNewsletter']) {
        if (!(name in data)) {
          data[name] = 'false';
        }
      }

      try {
        const res = await fetch('/api/admin/settings', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data),
        });
        const result = await res.json();
        if (result.success) {
          if (saveStatus) {
            saveStatus.textContent = '设置已保存';
            saveStatus.className = 'text-sm text-green-600';
          }
          setTimeout(() => {
            if (saveStatus) {
              saveStatus.textContent = '';
              saveStatus.className = 'text-sm text-foreground/60';
            }
          }, 3000);
        } else {
          alert('保存失败: ' + (result.error || '未知错误'));
        }
      } catch (err) {
        alert('请求失败: ' + err);
      }
    });
  </script>
</Layout>
