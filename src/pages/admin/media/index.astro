---
import Layout from "@/layouts/AdminLayout.astro";
import { Image, Upload, Copy, Trash2 } from "lucide-react";
---

<Layout title="Media Library">
  <!-- Header -->
  <div class="mb-6 flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
    <h1 class="text-2xl font-semibold" data-i18n="admin.mediaLibrary">Media Library</h1>
    
    <label class="inline-flex cursor-pointer items-center gap-2 rounded-lg bg-accent px-4 py-2 text-sm font-medium text-white hover:bg-accent/90">
      <Upload className="h-4 w-4" />
      <span data-i18n="admin.upload">Upload</span>
      <input type="file" class="hidden" accept="image/*" multiple id="media-upload" />
    </label>
  </div>

  <!-- Upload Area -->
  <div
    id="drop-zone"
    class="mb-8 rounded-xl border-2 border-dashed border-border bg-muted/30 p-12 text-center transition-colors hover:border-accent hover:bg-muted/50"
  >
    <Image className="mx-auto h-12 w-12 text-foreground/40" />
    <p class="mt-4 text-lg font-medium" data-i18n="admin.dropFiles">Drop files here</p>
    <p class="mt-2 text-sm text-foreground/60" data-i18n="admin.orClickUpload">or click to upload</p>
    <input type="file" class="hidden" accept="image/*" multiple id="drop-upload" />
  </div>

  <!-- Media Grid -->
  <div id="media-grid" class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
    <!-- Media items will be loaded here -->
    <div class="col-span-full py-12 text-center text-foreground/60">
      <Image className="mx-auto h-16 w-16 opacity-20" />
      <p class="mt-4" data-i18n="admin.noMedia">No media files yet</p>
      <p class="text-sm" data-i18n="admin.uploadFirst">Upload your first image</p>
    </div>
  </div>

  <script>
    const dropZone = document.getElementById('drop-zone');
    const dropUpload = document.getElementById('drop-upload');
    const mediaUpload = document.getElementById('media-upload');
    const mediaGrid = document.getElementById('media-grid');

    const renderEmpty = () => {
      if (!mediaGrid) return;
      mediaGrid.innerHTML = `
        <div class="col-span-full py-12 text-center text-foreground/60">
          <p class="mt-4">No media files yet</p>
          <p class="text-sm">Upload your first image</p>
        </div>
      `;
    };

    const renderMediaItem = (item) => {
      const card = document.createElement('div');
      card.className = 'group relative overflow-hidden rounded-xl border border-border bg-surface';
      card.dataset.id = item.id;
      card.innerHTML = `
        <img src="${item.url}" alt="${item.name}" class="aspect-square w-full object-cover" />
        <div class="absolute inset-0 flex items-center justify-center gap-2 bg-black/50 opacity-0 transition-opacity group-hover:opacity-100">
          <button class="copy-btn rounded-lg bg-white px-3 py-1 text-xs hover:bg-gray-100" type="button">Copy URL</button>
          <button class="delete-btn rounded-lg bg-white px-3 py-1 text-xs text-red-500 hover:bg-gray-100" type="button">Delete</button>
        </div>
        <div class="border-t border-border p-2">
          <p class="truncate text-xs text-foreground/60">${item.name}</p>
        </div>
      `;

      const copyBtn = card.querySelector('.copy-btn');
      const deleteBtn = card.querySelector('.delete-btn');

      copyBtn?.addEventListener('click', async () => {
        try {
          await navigator.clipboard.writeText(item.url);
          alert('URL copied to clipboard');
        } catch {
          alert('Failed to copy URL');
        }
      });

      deleteBtn?.addEventListener('click', async () => {
        if (!confirm('Delete this image?')) return;
        const response = await fetch(`/api/admin/media/${encodeURIComponent(item.id)}`, { method: 'DELETE' });
        if (!response.ok) {
          alert('Delete failed');
          return;
        }
        card.remove();
        if (mediaGrid && mediaGrid.children.length === 0) {
          renderEmpty();
        }
      });

      mediaGrid?.appendChild(card);
    };

    const loadMedia = async () => {
      if (!mediaGrid) return;
      const response = await fetch('/api/admin/media');
      if (!response.ok) {
        renderEmpty();
        return;
      }
      const payload = await response.json();
      const items = Array.isArray(payload.media) ? payload.media : [];
      mediaGrid.innerHTML = '';
      if (items.length === 0) {
        renderEmpty();
        return;
      }
      items.forEach(renderMediaItem);
    };

    const uploadFile = async (file) => {
      if (!file.type.startsWith('image/')) {
        return;
      }

      const dataUrl = await new Promise((resolve, reject) => {
        const reader = new FileReader();
        reader.onload = () => resolve(reader.result);
        reader.onerror = reject;
        reader.readAsDataURL(file);
      });

      if (typeof dataUrl !== 'string') {
        return;
      }

      const response = await fetch('/api/admin/media', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          name: file.name,
          url: dataUrl,
          mimeType: file.type,
          size: file.size,
        }),
      });

      if (!response.ok) {
        alert('Upload failed');
        return;
      }

      const payload = await response.json();
      if (payload.media && mediaGrid?.querySelector('.col-span-full')) {
        mediaGrid.innerHTML = '';
      }
      if (payload.media) {
        renderMediaItem(payload.media);
      }
    };

    const handleFiles = async (files) => {
      for (const file of files) {
        await uploadFile(file);
      }
    };

    dropZone?.addEventListener('dragover', e => {
      e.preventDefault();
      dropZone.classList.add('border-accent', 'bg-muted/50');
    });

    dropZone?.addEventListener('dragleave', () => {
      dropZone.classList.remove('border-accent', 'bg-muted/50');
    });

    dropZone?.addEventListener('drop', e => {
      e.preventDefault();
      dropZone.classList.remove('border-accent', 'bg-muted/50');
      const files = e.dataTransfer?.files;
      if (files) {
        void handleFiles(files);
      }
    });

    dropZone?.addEventListener('click', () => {
      dropUpload?.click();
    });

    dropUpload?.addEventListener('change', e => {
      const target = e.target;
      if (target instanceof HTMLInputElement && target.files) {
        void handleFiles(target.files);
      }
    });

    mediaUpload?.addEventListener('change', e => {
      const target = e.target;
      if (target instanceof HTMLInputElement && target.files) {
        void handleFiles(target.files);
      }
    });

    void loadMedia();
  </script>
</Layout>
