---
import Layout from "@/layouts/AdminLayout.astro";
---

<Layout title="媒体库">
  <!-- Header -->
  <div class="mb-6 flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
    <h1 class="text-2xl font-semibold">媒体库</h1>
    <label class="inline-flex cursor-pointer items-center gap-2 rounded-lg bg-accent px-4 py-2 text-sm font-medium text-white hover:bg-accent/90">
      + 上传
      <input type="file" class="hidden" accept="image/*,video/*,application/pdf" multiple id="media-upload" />
    </label>
  </div>

  <!-- Upload Area -->
  <div id="drop-zone"
    class="mb-8 rounded-xl border-2 border-dashed border-border bg-muted/30 p-12 text-center transition-colors hover:border-accent hover:bg-muted/50">
    <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="mx-auto text-foreground/30"><rect width="18" height="18" x="3" y="3" rx="2" ry="2"/><circle cx="9" cy="9" r="2"/><path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"/></svg>
    <p class="mt-4 text-lg font-medium">拖拽文件到这里</p>
    <p class="mt-2 text-sm text-foreground/60">支持图片、视频、PDF</p>
  </div>

  <!-- Upload Progress -->
  <div id="upload-progress" class="mb-4 hidden">
    <div class="rounded-lg border border-border bg-surface p-3">
      <div class="flex items-center gap-3">
        <div class="h-2 flex-1 rounded-full bg-muted">
          <div id="progress-bar" class="h-2 rounded-full bg-accent transition-all" style="width: 0%"></div>
        </div>
        <span id="progress-text" class="text-sm text-foreground/60">上传中...</span>
      </div>
    </div>
  </div>

  <!-- Media Grid -->
  <div id="media-grid" class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
    <div id="empty-state" class="col-span-full py-12 text-center text-foreground/60">
      <p class="mt-4">加载中...</p>
    </div>
  </div>
</Layout>

<script>
  const dropZone = document.getElementById('drop-zone');
  const mediaUpload = document.getElementById('media-upload') as HTMLInputElement;
  const mediaGrid = document.getElementById('media-grid');
  const emptyState = document.getElementById('empty-state');
  const uploadProgress = document.getElementById('upload-progress');
  const progressBar = document.getElementById('progress-bar');
  const progressText = document.getElementById('progress-text');

  // Load existing media on page load
  async function loadMedia() {
    try {
      const res = await fetch('/api/admin/media/list');
      const data = await res.json();
      if (data.success && data.items.length > 0) {
        if (emptyState) emptyState.remove();
        for (const item of data.items) {
          addMediaItem(item.url, item.filename, item.id, item.content_type);
        }
      } else {
        if (emptyState) emptyState.innerHTML = '<p>暂无媒体文件</p><p class="text-sm">上传你的第一个文件</p>';
      }
    } catch {
      if (emptyState) emptyState.innerHTML = '<p>暂无媒体文件</p><p class="text-sm">上传你的第一个文件</p>';
    }
  }
  loadMedia();

  // Drag & drop
  dropZone?.addEventListener('dragover', (e) => {
    e.preventDefault();
    dropZone.classList.add('border-accent', 'bg-accent/10');
  });

  dropZone?.addEventListener('dragleave', () => {
    dropZone.classList.remove('border-accent', 'bg-accent/10');
  });

  dropZone?.addEventListener('drop', (e) => {
    e.preventDefault();
    dropZone.classList.remove('border-accent', 'bg-accent/10');
    if (e.dataTransfer?.files) handleFiles(e.dataTransfer.files);
  });

  dropZone?.addEventListener('click', () => mediaUpload?.click());

  mediaUpload?.addEventListener('change', () => {
    if (mediaUpload.files) handleFiles(mediaUpload.files);
  });

  async function handleFiles(files: FileList) {
    const total = files.length;
    let uploaded = 0;

    if (uploadProgress) uploadProgress.classList.remove('hidden');

    for (const file of files) {
      if (progressText) progressText.textContent = `上传中... (${uploaded + 1}/${total})`;
      if (progressBar) progressBar.style.width = `${((uploaded) / total) * 100}%`;

      try {
        const formData = new FormData();
        formData.append('file', file);

        const res = await fetch('/api/admin/media/upload', {
          method: 'POST',
          body: formData,
        });
        const data = await res.json();

        if (data.success) {
          if (emptyState) emptyState.remove();
          addMediaItem(data.url, data.filename, null, data.contentType);
          uploaded++;
          if (progressBar) progressBar.style.width = `${(uploaded / total) * 100}%`;
        } else {
          alert(`上传失败 (${file.name}): ${data.error}`);
        }
      } catch (err) {
        alert(`上传失败 (${file.name}): ${err}`);
      }
    }

    if (progressText) progressText.textContent = '上传完成';
    setTimeout(() => {
      if (uploadProgress) uploadProgress.classList.add('hidden');
    }, 2000);
  }

  function addMediaItem(url: string, name: string, id: number | null, contentType?: string) {
    const isImage = contentType?.startsWith('image/') ?? /\.(jpg|jpeg|png|gif|webp|svg|avif)$/i.test(name);

    const item = document.createElement('div');
    item.className = 'group relative rounded-xl border border-border bg-surface overflow-hidden';

    const preview = isImage
      ? `<img src="${url}" alt="${name}" class="aspect-square w-full object-cover" loading="lazy" />`
      : `<div class="flex aspect-square w-full items-center justify-center bg-muted">
          <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-foreground/30"><path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"/><polyline points="14 2 14 8 20 8"/></svg>
        </div>`;

    item.innerHTML = `
      ${preview}
      <div class="absolute inset-0 flex items-center justify-center gap-2 bg-black/50 opacity-0 transition-opacity group-hover:opacity-100">
        <button class="copy-url-btn rounded-lg bg-white p-2 hover:bg-gray-100" title="复制 URL">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect width="14" height="14" x="8" y="8" rx="2"/><path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"/></svg>
        </button>
        <button class="delete-media-btn rounded-lg bg-white p-2 hover:bg-gray-100 text-red-500" title="删除">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 6h18"/><path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6"/><path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"/></svg>
        </button>
      </div>
      <div class="border-t border-border p-2">
        <p class="truncate text-xs text-foreground/60">${name}</p>
      </div>
    `;

    const copyBtn = item.querySelector('.copy-url-btn');
    copyBtn?.addEventListener('click', async () => {
      const fullUrl = new URL(url, window.location.origin).href;
      await navigator.clipboard.writeText(fullUrl);
      const el = copyBtn as HTMLElement;
      el.title = '已复制!';
      setTimeout(() => { el.title = '复制 URL'; }, 2000);
    });

    const deleteBtn = item.querySelector('.delete-media-btn');
    deleteBtn?.addEventListener('click', async () => {
      if (!confirm(`确定要删除 "${name}" 吗？`)) return;
      try {
        const res = await fetch('/api/admin/media/delete', {
          method: 'DELETE',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ id, url }),
        });
        const data = await res.json();
        if (data.success) {
          item.remove();
          if (mediaGrid && mediaGrid.children.length === 0) {
            mediaGrid.innerHTML = '<div class="col-span-full py-12 text-center text-foreground/60"><p>暂无媒体文件</p></div>';
          }
        } else {
          alert('删除失败: ' + (data.error || '未知错误'));
        }
      } catch {
        alert('删除请求失败');
      }
    });

    mediaGrid?.prepend(item);
  }
</script>
