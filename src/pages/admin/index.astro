---
import Layout from "@/layouts/AdminLayout.astro";
import PostsChart from "@/components/admin/PostsChart";
import { getCollection } from "astro:content";
import { getD1, PostsRepo } from "@/db";

// Get markdown posts
const mdPosts = await getCollection("blog");

// Get D1 posts
let dbPosts: Awaited<ReturnType<typeof PostsRepo.findAll>> = [];
const db = getD1(Astro.locals);
if (db) {
  try {
    dbPosts = await PostsRepo.findAll(db);
  } catch { /* D1 not available */ }
}

// Stats
const mdTotal = mdPosts.length;
const mdPublished = mdPosts.filter(p => !p.data.draft).length;
const dbTotal = dbPosts.length;
const dbPublished = dbPosts.filter(p => p.draft === 0).length;

const totalPosts = mdTotal + dbTotal;
const publishedPosts = mdPublished + dbPublished;
const draftPosts = totalPosts - publishedPosts;

// This month
const now = new Date();
const firstOfMonth = new Date(now.getFullYear(), now.getMonth(), 1);
const mdThisMonth = mdPosts.filter(p => p.data.pubDatetime >= firstOfMonth && !p.data.draft).length;
const dbThisMonth = dbPosts.filter(p => {
  const d = new Date(p.pub_datetime);
  return d >= firstOfMonth && p.draft === 0;
}).length;
const thisMonth = mdThisMonth + dbThisMonth;

// Monthly chart data (last 6 months)
const monthNames = ["1月", "2月", "3月", "4月", "5月", "6月", "7月", "8月", "9月", "10月", "11月", "12月"];
const chartData: { month: string; posts: number }[] = [];
for (let i = 5; i >= 0; i--) {
  const d = new Date(now.getFullYear(), now.getMonth() - i, 1);
  const endD = new Date(d.getFullYear(), d.getMonth() + 1, 0, 23, 59, 59);
  const label = `${d.getFullYear()}/${monthNames[d.getMonth()]}`;

  const mdCount = mdPosts.filter(p => {
    const pd = new Date(p.data.pubDatetime);
    return pd >= d && pd <= endD && !p.data.draft;
  }).length;
  const dbCount = dbPosts.filter(p => {
    const pd = new Date(p.pub_datetime);
    return pd >= d && pd <= endD && p.draft === 0;
  }).length;

  chartData.push({ month: label, posts: mdCount + dbCount });
}

// Recent posts (combined, sorted)
type RecentPost = { slug: string; title: string; draft: boolean; pubDatetime: Date; source: string };
const allRecent: RecentPost[] = [
  ...mdPosts.map(p => ({
    slug: p.id,
    title: p.data.title,
    draft: p.data.draft ?? false,
    pubDatetime: new Date(p.data.pubDatetime),
    source: "md" as const,
  })),
  ...dbPosts.map(p => ({
    slug: p.slug,
    title: p.title,
    draft: p.draft === 1,
    pubDatetime: new Date(p.pub_datetime),
    source: "db" as const,
  })),
].sort((a, b) => b.pubDatetime.getTime() - a.pubDatetime.getTime()).slice(0, 5);

const formatDate = (date: Date) =>
  new Intl.DateTimeFormat("zh-CN", { year: "numeric", month: "short", day: "numeric" }).format(date);
---

<Layout title="仪表盘">
  <!-- Stats Cards -->
  <div class="mb-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
    <div class="rounded-xl border border-border bg-surface p-6 shadow-sm">
      <p class="text-sm text-foreground/60">文章总数</p>
      <p class="mt-2 text-3xl font-bold">{totalPosts}</p>
    </div>
    <div class="rounded-xl border border-border bg-surface p-6 shadow-sm">
      <p class="text-sm text-foreground/60">已发布</p>
      <p class="mt-2 text-3xl font-bold text-green-600">{publishedPosts}</p>
    </div>
    <div class="rounded-xl border border-border bg-surface p-6 shadow-sm">
      <p class="text-sm text-foreground/60">草稿</p>
      <p class="mt-2 text-3xl font-bold text-yellow-600">{draftPosts}</p>
    </div>
    <div class="rounded-xl border border-border bg-surface p-6 shadow-sm">
      <p class="text-sm text-foreground/60">本月发布</p>
      <p class="mt-2 text-3xl font-bold text-blue-600">{thisMonth}</p>
    </div>
  </div>

  <!-- Monthly Chart -->
  <div class="mb-8 rounded-xl border border-border bg-surface p-6 shadow-sm">
    <h2 class="mb-4 text-lg font-semibold">发布趋势 (近6个月)</h2>
    <PostsChart client:only="react" data={chartData} />
  </div>

  <!-- Quick Actions -->
  <div class="mb-8">
    <h2 class="mb-4 text-lg font-semibold">快捷操作</h2>
    <div class="flex flex-wrap gap-3">
      <a href="/admin/posts/new" class="inline-flex items-center gap-2 rounded-lg bg-accent px-4 py-2 text-sm font-medium text-white hover:bg-accent/90">
        + 新建文章
      </a>
      <a href="/admin/media" class="inline-flex items-center gap-2 rounded-lg border border-border bg-surface px-4 py-2 text-sm font-medium hover:bg-muted">
        上传媒体
      </a>
    </div>
  </div>

  <!-- Recent Posts -->
  <div>
    <div class="mb-4 flex items-center justify-between">
      <h2 class="text-lg font-semibold">最近文章</h2>
      <a href="/admin/posts" class="text-sm text-accent hover:underline">查看全部 →</a>
    </div>

    <div class="overflow-hidden rounded-xl border border-border bg-surface">
      <table class="w-full">
        <thead class="border-b border-border bg-muted/50">
          <tr>
            <th class="px-6 py-3 text-left text-sm font-medium text-foreground/60">标题</th>
            <th class="px-6 py-3 text-left text-sm font-medium text-foreground/60">状态</th>
            <th class="px-6 py-3 text-left text-sm font-medium text-foreground/60">来源</th>
            <th class="px-6 py-3 text-left text-sm font-medium text-foreground/60">日期</th>
            <th class="px-6 py-3 text-right text-sm font-medium text-foreground/60">操作</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-border">
          {allRecent.map(post => (
            <tr class="hover:bg-muted/30">
              <td class="px-6 py-4">
                <span class="font-medium">{post.title}</span>
              </td>
              <td class="px-6 py-4">
                <span class:list={[
                  "inline-flex rounded-full px-2 py-1 text-xs font-medium",
                  post.draft
                    ? "bg-yellow-100 text-yellow-800"
                    : "bg-green-100 text-green-800",
                ]}>
                  {post.draft ? "草稿" : "已发布"}
                </span>
              </td>
              <td class="px-6 py-4 text-sm text-foreground/60">
                {post.source === "md" ? "Markdown" : "数据库"}
              </td>
              <td class="px-6 py-4 text-sm text-foreground/60">
                {formatDate(post.pubDatetime)}
              </td>
              <td class="px-6 py-4 text-right">
                <div class="flex justify-end gap-2">
                  <a href={`/admin/posts/${post.slug}`} class="rounded p-1 text-sm text-accent hover:underline" title="编辑">
                    编辑
                  </a>
                  {!post.draft && (
                    <a href={`/blog/${post.slug}/`} target="_blank" class="rounded p-1 text-sm text-foreground/60 hover:text-foreground" title="查看">
                      查看
                    </a>
                  )}
                </div>
              </td>
            </tr>
          ))}
          {allRecent.length === 0 && (
            <tr>
              <td colspan="5" class="px-6 py-8 text-center text-foreground/60">暂无文章</td>
            </tr>
          )}
        </tbody>
      </table>
    </div>
  </div>
</Layout>
