---
import Layout from "@/layouts/AdminLayout.astro";
import { getCollection } from "astro:content";
import { FileText, Image, Plus, TrendingUp, Edit, Eye } from "lucide-react";

// Get posts data
const posts = await getCollection("blog");
const totalPosts = posts.length;
const publishedPosts = posts.filter(p => !p.data.draft).length;
const draftPosts = posts.filter(p => p.data.draft).length;
const recentPosts = posts
  .sort((a, b) => b.data.pubDatetime.valueOf() - a.data.pubDatetime.valueOf())
  .slice(0, 5);

// Format date
const formatDate = (date: Date) => {
  return new Intl.DateTimeFormat("zh-CN", {
    year: "numeric",
    month: "short",
    day: "numeric",
  }).format(date);
};
---

<Layout title="Dashboard">
  <!-- Stats Cards -->
  <div class="mb-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
    <div class="rounded-xl border border-border bg-surface p-6 shadow-sm">
      <div class="flex items-center justify-between">
        <div>
          <p class="text-sm text-foreground/60" data-i18n="admin.totalPosts">Total Posts</p>
          <p class="mt-2 text-3xl font-bold">{totalPosts}</p>
        </div>
        <div class="rounded-lg bg-accent/10 p-3">
          <FileText className="h-6 w-6 text-accent" />
        </div>
      </div>
    </div>

    <div class="rounded-xl border border-border bg-surface p-6 shadow-sm">
      <div class="flex items-center justify-between">
        <div>
          <p class="text-sm text-foreground/60" data-i18n="admin.published">Published</p>
          <p class="mt-2 text-3xl font-bold text-green-600">{publishedPosts}</p>
        </div>
        <div class="rounded-lg bg-green-100 p-3 dark:bg-green-900/20">
          <TrendingUp className="h-6 w-6 text-green-600" />
        </div>
      </div>
    </div>

    <div class="rounded-xl border border-border bg-surface p-6 shadow-sm">
      <div class="flex items-center justify-between">
        <div>
          <p class="text-sm text-foreground/60" data-i18n="admin.drafts">Drafts</p>
          <p class="mt-2 text-3xl font-bold text-yellow-600">{draftPosts}</p>
        </div>
        <div class="rounded-lg bg-yellow-100 p-3 dark:bg-yellow-900/20">
          <Edit className="h-6 w-6 text-yellow-600" />
        </div>
      </div>
    </div>

    <div class="rounded-xl border border-border bg-surface p-6 shadow-sm">
      <div class="flex items-center justify-between">
        <div>
          <p class="text-sm text-foreground/60" data-i18n="admin.thisMonth">This Month</p>
          <p class="mt-2 text-3xl font-bold text-blue-600">
            {posts.filter(p => {
              const now = new Date();
              const postDate = p.data.pubDatetime;
              return postDate.getMonth() === now.getMonth() && 
                     postDate.getFullYear() === now.getFullYear();
            }).length}
          </p>
        </div>
        <div class="rounded-lg bg-blue-100 p-3 dark:bg-blue-900/20">
          <TrendingUp className="h-6 w-6 text-blue-600" />
        </div>
      </div>
    </div>
  </div>

  <!-- Quick Actions -->
  <div class="mb-8">
    <h2 class="mb-4 text-lg font-semibold" data-i18n="admin.quickActions">Quick Actions</h2>
    <div class="flex flex-wrap gap-3">
      <a
        href="/admin/posts/new"
        class="inline-flex items-center gap-2 rounded-lg bg-accent px-4 py-2 text-sm font-medium text-white hover:bg-accent/90"
      >
        <Plus className="h-4 w-4" />
        <span data-i18n="admin.newPost">New Post</span>
      </a>

      <a
        href="/admin/media"
        class="inline-flex items-center gap-2 rounded-lg border border-border bg-surface px-4 py-2 text-sm font-medium hover:bg-muted"
      >
        <Image className="h-4 w-4" />
        <span data-i18n="admin.uploadMedia">Upload Media</span>
      </a>
    </div>
  </div>

  <!-- Recent Posts -->
  <div>
    <div class="mb-4 flex items-center justify-between">
      <h2 class="text-lg font-semibold" data-i18n="admin.recentPosts">Recent Posts</h2>
      <a
        href="/admin/posts"
        class="text-sm text-accent hover:underline"
        data-i18n="admin.viewAll"
      >
        View All →
      </a>
    </div>

    <div class="overflow-hidden rounded-xl border border-border bg-surface">
      <table class="w-full">
        <thead class="border-b border-border bg-muted/50">
          <tr>
            <th class="px-6 py-3 text-left text-sm font-medium text-foreground/60">Title</th>
            <th class="px-6 py-3 text-left text-sm font-medium text-foreground/60">Status</th>
            <th class="px-6 py-3 text-left text-sm font-medium text-foreground/60">Date</th>
            <th class="px-6 py-3 text-right text-sm font-medium text-foreground/60">Actions</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-border">
          {recentPosts.map((post) => (
            <tr key={post.id} class="hover:bg-muted/30">
              <td class="px-6 py-4">
                <a
                  href={`/blog/${post.slug}/`}
                  target="_blank"
                  class="font-medium hover:text-accent"
                >
                  {post.data.title}
                </a>
              </td>
              <td class="px-6 py-4">
                <span
                  class={`inline-flex rounded-full px-2 py-1 text-xs font-medium ${
                    post.data.draft
                      ? "bg-yellow-100 text-yellow-800 dark:bg-yellow-900/30 dark:text-yellow-400"
                      : "bg-green-100 text-green-800 dark:bg-green-900/30 dark:text-green-400"
                  }`}
                >
                  {post.data.draft ? "Draft" : "Published"}
                </span>
              </td>
              <td class="px-6 py-4 text-sm text-foreground/60">
                {formatDate(post.data.pubDatetime)}
              </td>
              <td class="px-6 py-4 text-right">
                <div class="flex justify-end gap-2">
                  <a
                    href={`/admin/posts/${post.slug}`}
                    class="rounded p-1 hover:bg-muted"
                    title="Edit"
                  >
                    <Edit className="h-4 w-4" />
                  </a>
                  <a
                    href={`/blog/${post.slug}/`}
                    target="_blank"
                    class="rounded p-1 hover:bg-muted"
                    title="View"
                  >
                    <Eye className="h-4 w-4" />
                  </a>
                </div>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </div>
</Layout>
