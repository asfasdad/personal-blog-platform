---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import { SITE } from "@/config";

export const prerender = false;
---

<Layout title={`Admin Console | ${SITE.title}`} noIndex={true}>
  <Header />
  <main id="main-content" class="app-layout mt-8">
    <section class="rounded-2xl border border-border bg-surface p-6 shadow-[var(--shadow-soft)]" data-pagefind-ignore>
      <h1 class="text-2xl font-semibold">Admin Operations Console</h1>
      <p class="mt-2 text-foreground/80">Owner-only controls for publish, rollback, pause, and workflow visibility.</p>

      <div class="mt-5 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
        <article class="rounded-xl border border-border bg-background p-4">
          <h2 class="text-sm ui-label">Latest Workflow</h2>
          <p id="admin-latest-workflow" class="mt-2 text-lg font-semibold">Loading...</p>
        </article>
        <article class="rounded-xl border border-border bg-background p-4">
          <h2 class="text-sm ui-label">Latest Deploy</h2>
          <p id="admin-latest-deploy" class="mt-2 text-lg font-semibold">Loading...</p>
        </article>
        <article class="rounded-xl border border-border bg-background p-4">
          <h2 class="text-sm ui-label">Draft Queue</h2>
          <p id="admin-draft-queue" class="mt-2 text-lg font-semibold">Loading...</p>
        </article>
        <article class="rounded-xl border border-border bg-background p-4">
          <h2 class="text-sm ui-label">Emergency Pause</h2>
          <p id="admin-pause-state" class="mt-2 text-lg font-semibold">Loading...</p>
        </article>
      </div>

      <div class="mt-6 flex flex-wrap gap-3">
        <button class="admin-action rounded-lg border border-border bg-surface-strong px-3 py-2" data-action="publish">Trigger Publish</button>
        <button class="admin-action rounded-lg border border-border bg-surface-strong px-3 py-2" data-action="rollback">Rollback</button>
        <button class="admin-action rounded-lg border border-border bg-surface-strong px-3 py-2" data-action="pause">Pause</button>
        <button class="admin-action rounded-lg border border-border bg-surface-strong px-3 py-2" data-action="resume">Resume</button>
        <form method="post" action="/api/admin/logout">
          <button type="submit" class="rounded-lg border border-border bg-background px-3 py-2">Logout</button>
        </form>
      </div>

      <p id="admin-action-status" class="mt-4 text-sm text-foreground/85" aria-live="polite"></p>

      <div class="mt-6">
        <h2 class="text-lg font-semibold">Audit Feed</h2>
        <ul id="admin-audit-feed" class="mt-3 space-y-2 text-sm"></ul>
      </div>
    </section>

    <script is:inline>
      const workflowNode = document.querySelector("#admin-latest-workflow");
      const deployNode = document.querySelector("#admin-latest-deploy");
      const draftNode = document.querySelector("#admin-draft-queue");
      const pauseNode = document.querySelector("#admin-pause-state");
      const statusNode = document.querySelector("#admin-action-status");
      const auditFeed = document.querySelector("#admin-audit-feed");

      const setText = (node, value) => {
        if (node instanceof HTMLElement) node.textContent = value;
      };

      const renderAudit = items => {
        if (!(auditFeed instanceof HTMLUListElement)) return;
        auditFeed.innerHTML = "";
        for (const item of items) {
          const li = document.createElement("li");
          li.className = "rounded-lg border border-border bg-background px-3 py-2";
          li.textContent = `${item.timestamp} - ${item.action}: ${item.status}`;
          auditFeed.appendChild(li);
        }
      };

      const loadStatus = async () => {
        const response = await fetch("/api/admin/status");
        if (!response.ok) {
          setText(statusNode, "Unable to load admin status.");
          return;
        }

        const payload = await response.json();
        setText(workflowNode, payload.latestWorkflow);
        setText(deployNode, payload.latestDeploy);
        setText(draftNode, String(payload.draftQueue));
        setText(pauseNode, payload.emergencyPaused ? "Paused" : "Running");
        renderAudit(payload.audit ?? []);
      };

      const triggerAction = async action => {
        setText(statusNode, `Running ${action}...`);
        const response = await fetch("/api/admin/actions", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ action }),
        });

        const payload = await response.json().catch(() => null);
        if (response.ok && payload) {
          setText(statusNode, `${action} completed (${payload.result}).`);
          await loadStatus();
          return;
        }

        setText(statusNode, `${action} failed. Please retry.`);
      };

      document.querySelectorAll(".admin-action").forEach(button => {
        button.addEventListener("click", event => {
          const target = event.currentTarget;
          if (!(target instanceof HTMLButtonElement)) return;
          triggerAction(target.dataset.action ?? "");
        });
      });

      loadStatus();
    </script>
  </main>
  <Footer />
</Layout>
