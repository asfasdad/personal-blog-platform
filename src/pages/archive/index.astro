---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import { SITE } from "@/config";

export const prerender = true;
---

<Layout title={`Archive | ${SITE.title}`}>
  <Header />
  <main id="main-content" class="app-layout">
    <h1 class="text-2xl font-semibold sm:text-3xl">Archive</h1>
    <div class="mt-8 rounded-2xl border border-border bg-surface px-6 py-8 shadow-[var(--shadow-soft)]">
      <p>
        Archive timeline is available in the managed publishing workflow.
      </p>
      <a class="mt-3 inline-block text-accent underline" href="/blog/">
        Browse latest blog entries
      </a>
    </div>
  </main>
  <Footer />
</Layout>
