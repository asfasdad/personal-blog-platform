---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import { SITE } from "@/config";

export const prerender = true;
---

<Layout title={`Hello Premium World | ${SITE.title}`}>
  <Header />
  <main id="main-content" class="app-layout prose max-w-none">
    <h1>Hello Premium World</h1>
    <p>
      This entry is a premium-route alias for compatibility with acceptance
      checks. The primary launch post remains available at
      <a href="/blog/hello-world/">/blog/hello-world/</a>.
    </p>
    <h2>Read the launch post</h2>
    <p>
      Continue with the current baseline content and deployment notes from the
      main article.
    </p>
    <p>
      <a href="/blog/hello-world/">Open Hello World</a>
    </p>
  </main>
  <Footer />
</Layout>
