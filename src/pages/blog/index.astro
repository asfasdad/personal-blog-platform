---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import { SITE } from "@/config";

export const prerender = true;
---

<Layout title={`Blog | ${SITE.title}`}>
  <Header />
  <main id="main-content" class="app-layout">
    <h1 class="text-2xl font-semibold sm:text-3xl">Blog</h1>
    <p class="mt-4 max-w-2xl text-lg">
      Curated engineering notes, platform updates, and workflow writeups.
    </p>

    <section class="mt-8 rounded-2xl border border-border bg-surface px-6 py-8 shadow-[var(--shadow-soft)]">
      <h2 class="text-xl font-semibold">Latest Article</h2>
      <p class="mt-2 text-sm opacity-80">Hello World</p>
      <a class="mt-4 inline-block text-accent underline" href="/blog/hello-world/">
        Read article
      </a>
    </section>
  </main>
  <Footer />
</Layout>
