---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import { SITE } from "@/config";
import Datetime from "@/components/Datetime.astro";
import { getAllPosts } from "@/utils/getAllPosts";

const sortedPosts = await getAllPosts(Astro.locals);
---

<Layout title={`博客 | ${SITE.title}`}>
  <Header />
  <main id="main-content" class="app-layout">
    <h1 class="text-2xl font-semibold sm:text-3xl" data-i18n="blog.title">博客</h1>
    <p class="mt-4 max-w-2xl text-lg text-foreground/80" data-i18n="blog.desc">技术笔记、项目记录与工作流分享。</p>

    <section class="mt-8">
      {sortedPosts.length === 0 && (
        <p class="text-foreground/60">暂无文章。</p>
      )}
      <ul class="space-y-6">
        {sortedPosts.map(post => (
          <li class="my-6">
            <a
              href={`/blog/${post.slug}/`}
              class="inline-block text-lg font-medium text-accent decoration-dashed underline-offset-4 hover:underline focus-visible:no-underline focus-visible:underline-offset-0"
            >
              <h2>
                {post.title}
              </h2>
            </a>
            <Datetime pubDatetime={post.pubDatetime} modDatetime={post.modDatetime} />
            <p class="mt-2 text-foreground/80">{post.description}</p>
          </li>
        ))}
      </ul>
    </section>
  </main>
  <Footer />
</Layout>
