---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import { SITE } from "@/config";
import Datetime from "@/components/Datetime.astro";
import Tag from "@/components/Tag.astro";

export const prerender = true;

const post = {
  title: "我如何用 Astro + Cloudflare 搭建了这个博客",
  description: "从零开始搭建一个支持中英双语、RSS、搜索功能的个人博客，并部署到 Cloudflare 的完整实战记录",
  pubDatetime: new Date("2026-03-16T12:00:00+08:00"),
  modDatetime: undefined,
  tags: ["astro", "cloudflare", "博客系统", "工程实践", "部署"],
};
---

<Layout title={`${post.title} | ${SITE.title}`}>
  <Header />
  <main id="main-content" class="app-layout">
    <article class="prose max-w-none">
      <header class="mb-8">
        <Datetime pubDatetime={post.pubDatetime} modDatetime={post.modDatetime} size="lg" className="my-2" />
        <h1 class="text-3xl font-bold">{post.title}</h1>
        <p class="mt-4 text-lg text-foreground/80">{post.description}</p>
        
        <ul class="mt-4 flex flex-wrap gap-2">
          {post.tags.map(tag => (
            <Tag name={tag} />
          ))}
        </ul>
      </header>

      <div class="my-8 rounded-lg border border-border bg-surface p-6">
        <p class="m-0 mb-2 text-sm font-semibold">📌 本文面向</p>
        <p class="m-0 text-sm text-foreground/80">想要搭建个人博客但不知道从何下手的人，以及想了解 Astro + Cloudflare 技术栈实际落地细节的技术爱好者。</p>
        
        <p class="m-0 mb-2 mt-4 text-sm font-semibold">🎯 读完本文你能</p>
        <p class="m-0 text-sm text-foreground/80">了解一个博客系统的完整技术选型、搭建步骤、遇到的真实问题及解决方案，并获得一套可直接参考的部署流程。</p>
      </div>

      <div class="prose-headings:mb-3 prose-headings:text-foreground">
        <h2>问题场景</h2>
        <p>在动手之前，我需要明确一个问题：<strong>我为什么要花时间搭这个博客？</strong></p>
        <p>之前尝试过几种方案：</p>
        <ul>
          <li><strong>Notion + 公开页面</strong> —— 简单，但自定义能力几乎为零，访问速度不稳定</li>
          <li><strong>Hexo/Jekyll</strong> —— 成熟，但配置繁琐，主题修改需要了解很多约定</li>
          <li><strong>WordPress</strong> —— 功能强大，但需要服务器和维护，成本高</li>
        </ul>
        <p>我想要的是一个<strong>平衡方案</strong>：足够简单、足够灵活、足够快、足够便宜（最好免费）。最终选择了 <strong>Astro + Cloudflare</strong>。</p>

        <h2>为什么选择 Astro？</h2>
        <p><strong>Astro</strong> 是一个现代的前端框架，它的核心特点是：</p>
        <blockquote class="rounded-lg border-l-4 border-accent bg-surface/50 p-4 italic">
          <strong>群岛架构（Islands Architecture）</strong> —— 页面大部分是静态 HTML，只有需要交互的部分才加载 JavaScript。
        </blockquote>
        <p>这意味着我的博客页面加载后，不需要等待复杂的 JavaScript 执行，浏览器直接显示内容。这对阅读体验来说是巨大的提升。</p>

        <h2>为什么选择 Cloudflare？</h2>
        <p><strong>Cloudflare Workers</strong> 是一个边缘计算平台，简单来说：</p>
        <blockquote class="rounded-lg border-l-4 border-accent bg-surface/50 p-4 italic">
          你的代码运行在离用户最近的服务器上，而不是集中在某个数据中心。
        </blockquote>
        <p>这带来了两个好处：</p>
        <ol>
          <li><strong>速度快</strong> —— 全球用户访问都快</li>
          <li><strong>免费额度充足</strong> —— 个人博客几乎不可能超出免费限额</li>
        </ol>

        <h2>详细步骤</h2>
        
        <h3>Step 1: 初始化项目</h3>
        <pre class="rounded-lg bg-surface-strong border border-border p-4 text-sm shadow-sm" style="background-color: #e8dfd1;"><code style="color: #1f1c17;">npm create astro@latest personal-blog-platform</code></pre>

        <h3>Step 2: 配置站点</h3>
        <p>修改 src/config.ts：</p>
        <pre class="rounded-lg bg-surface-strong border border-border p-4 text-sm shadow-sm" style="background-color: #e8dfd1;"><code style="color: #1f1c17;">export const SITE = {{
  website: "https://blog.158247.xyz",
  author: "你的名字",
  title: "Personal Blog",
  desc: "A personal blog built with Astro.",
}} as const;</code></pre>

        <h3>Step 3: 部署</h3>
        <pre class="rounded-lg bg-surface-strong border border-border p-4 text-sm shadow-sm" style="background-color: #e8dfd1;"><code style="color: #1f1c17;">pnpm dlx wrangler deploy --config dist/server/wrangler.json</code></pre>

        <h2>踩坑记录</h2>
        <h3>坑 1: RSS 链接 500 错误</h3>
        <p><strong>现象：</strong>RSS 能生成，但点击文章链接报 500。</p>
        <p><strong>原因：</strong>文章 slug 生成逻辑不一致。</p>
        <p><strong>解决：</strong>修复 RSS 生成逻辑，添加兼容性路由。</p>

        <h3>坑 2: 搜索资源 404</h3>
        <p><strong>现象：</strong>搜索页面没有搜索框，控制台报错。</p>
        <p><strong>原因：</strong>Pagefind 索引没有正确生成。</p>
        <p><strong>解决：</strong>确保构建脚本包含 Pagefind 生成。</p>

        <h2>总结与建议</h2>
        <p>如果你也想搭类似博客：</p>
        <ol>
          <li><strong>先跑起来</strong> —— 不要追求完美，先把第一篇内容发出去</li>
          <li><strong>再优化</strong> —— 根据实际使用情况逐步改进</li>
          <li><strong>写检查清单</strong> —— 把部署流程固化成 checklist</li>
        </ol>

        <hr class="my-8" />
        <p class="text-sm text-foreground/70"><strong>写在最后：</strong>搭建博客不是目的，持续写作才是。技术细节可以随时改，但写作习惯需要长期培养。</p>
      </div>
    </article>
  </main>
  <Footer />
</Layout>
