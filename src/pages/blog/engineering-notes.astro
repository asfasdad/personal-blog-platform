---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import { SITE } from "@/config";

export const prerender = true;
---

<Layout title={`Engineering Notes on Static Publishing | ${SITE.title}`}>
  <Header />
  <main id="main-content" class="app-layout prose max-w-none">
    <h1>Engineering Notes on Static Publishing</h1>
    <p>
      Notes from tuning a static publishing pipeline for reliable previews and deploys.
    </p>
    <h2>Highlights</h2>
    <ul>
      <li>Use stable build artifacts for search and feed endpoints.</li>
      <li>Keep route checks in automated smoke validation.</li>
      <li>Verify bilingual shell behavior in E2E before release.</li>
    </ul>
  </main>
  <Footer />
</Layout>
