---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import { SITE } from "@/config";

export const prerender = true;
---

<Layout title={`Hello World | ${SITE.title}`}>
  <Header />
  <main id="main-content" class="app-layout prose max-w-none">
    <h1>Hello World</h1>
    <p>
      Welcome to the production blog runtime. This route is statically rendered
      to keep Cloudflare Worker runtime stable while preserving the content experience.
    </p>
    <h2>What is included</h2>
    <ul>
      <li>Public homepage and blog routes</li>
      <li>Search page and newsletter entry point</li>
      <li>Protected admin area</li>
    </ul>
  </main>
  <Footer />
</Layout>
