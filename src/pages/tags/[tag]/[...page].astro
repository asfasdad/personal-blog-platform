---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Datetime from "@/components/Datetime.astro";
import { getAllPosts, type UnifiedPost } from "@/utils/getAllPosts";
import { slugifyStr } from "@/utils/slugify";
import { SITE } from "@/config";

const { tag } = Astro.params;
if (!tag) return Astro.redirect("/tags/");

const allPosts = await getAllPosts(Astro.locals);
const tagPosts = allPosts.filter(post =>
  post.tags.some(t => slugifyStr(t) === tag)
);

// Find original tag name
const tagName = tagPosts.length > 0
  ? tagPosts[0].tags.find(t => slugifyStr(t) === tag) ?? tag
  : tag;
---

<Layout title={`标签: ${tagName} | ${SITE.title}`}>
  <Header />
  <main id="main-content" class="app-layout">
    <h1 class="text-2xl font-semibold sm:text-3xl">
      标签: <span class="text-accent">{tagName}</span>
    </h1>
    <p class="mt-2 text-foreground/60">共 {tagPosts.length} 篇文章</p>
    <ul class="mt-6 space-y-6">
      {tagPosts.map(post => (
        <li class="my-6">
          <a
            href={`/blog/${post.slug}/`}
            class="inline-block text-lg font-medium text-accent decoration-dashed underline-offset-4 hover:underline"
          >
            <h2>{post.title}</h2>
          </a>
          <Datetime pubDatetime={post.pubDatetime} modDatetime={post.modDatetime} />
          <p class="mt-2 text-foreground/80">{post.description}</p>
        </li>
      ))}
    </ul>
    {tagPosts.length === 0 && (
      <p class="mt-8 text-foreground/60">该标签下暂无文章。</p>
    )}
  </main>
  <Footer />
</Layout>
