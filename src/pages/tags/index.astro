---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Tag from "@/components/Tag.astro";
import { getAllTags } from "@/utils/getAllPosts";
import { slugifyStr } from "@/utils/slugify";
import { SITE } from "@/config";

const tags = await getAllTags(Astro.locals);
---

<Layout title={`标签 | ${SITE.title}`}>
  <Header />
  <main id="main-content" class="app-layout">
    <h1 class="text-2xl font-semibold sm:text-3xl">标签</h1>
    <ul class="mt-4 flex flex-wrap gap-4">
      {tags.map(tag => (
        <Tag tag={slugifyStr(tag)} tagName={tag} size="lg" />
      ))}
    </ul>
  </main>
  <Footer />
</Layout>
