---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Datetime from "@/components/Datetime.astro";
import { getAllPosts, type UnifiedPost } from "@/utils/getAllPosts";
import { SITE } from "@/config";

const sortedPosts = await getAllPosts(Astro.locals);

// Group posts by year
const postsByYear = sortedPosts.reduce(
  (acc, post) => {
    const year = post.pubDatetime.getFullYear();
    if (!acc[year]) acc[year] = [];
    acc[year].push(post);
    return acc;
  },
  {} as Record<number, UnifiedPost[]>
);

const years = Object.keys(postsByYear)
  .map(Number)
  .sort((a, b) => b - a);
---

<Layout title={`归档 | ${SITE.title}`}>
  <Header />
  <main id="main-content" class="app-layout">
    <h1 class="text-2xl font-semibold sm:text-3xl">归档</h1>
    <div class="mt-8">
      {
        years.map(year => (
          <section class="mb-8">
            <h2 class="text-xl font-semibold mb-4">{year}</h2>
            <ul class="space-y-4">
              {postsByYear[year].map(post => (
                <li class="flex flex-col sm:flex-row sm:items-center gap-2">
                  <Datetime
                    pubDatetime={post.pubDatetime}
                    modDatetime={post.modDatetime}
                    size="sm"
                  />
                  <a
                    href={`/blog/${post.slug}/`}
                    class="text-accent hover:underline"
                  >
                    {post.title}
                  </a>
                </li>
              ))}
            </ul>
          </section>
        ))
      }
    </div>
  </main>
  <Footer />
</Layout>
