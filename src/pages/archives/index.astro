---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Datetime from "@/components/Datetime.astro";
import getSortedPosts from "@/utils/getSortedPosts";
import { getPath } from "@/utils/getPath";
import { SITE } from "@/config";

const posts = await getCollection("blog");
const sortedPosts = getSortedPosts(posts);

// Group posts by year
const postsByYear = sortedPosts.reduce(
  (acc, post) => {
    const year = new Date(post.data.pubDatetime).getFullYear();
    if (!acc[year]) acc[year] = [];
    acc[year].push(post);
    return acc;
  },
  {} as Record<number, typeof sortedPosts>
);

const years = Object.keys(postsByYear)
  .map(Number)
  .sort((a, b) => b - a);
---

<Layout title={`Archives | ${SITE.title}`}>
  <Header />
  <main id="main-content" class="app-layout">
    <h1 class="text-2xl font-semibold sm:text-3xl">Archives</h1>
    <div class="mt-8">
      {
        years.map(year => (
          <section class="mb-8">
            <h2 class="text-xl font-semibold mb-4">{year}</h2>
            <ul class="space-y-4">
              {postsByYear[year].map(post => (
                <li class="flex flex-col sm:flex-row sm:items-center gap-2">
                  <Datetime
                    pubDatetime={post.data.pubDatetime}
                    modDatetime={post.data.modDatetime}
                    size="sm"
                  />
                  <a
                    href={getPath(post.id, post.filePath)}
                    class="text-accent hover:underline"
                  >
                    {post.data.title}
                  </a>
                </li>
              ))}
            </ul>
          </section>
        ))
      }
    </div>
  </main>
  <Footer />
</Layout>
