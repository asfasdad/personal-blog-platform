{
  "name": "personal-blog-platform",
  "private": true,
  "packageManager": "pnpm@8.15.9",
  "type": "module",
  "scripts": {
    "lint": "eslint \"src/**/*.{ts,tsx,js}\" --quiet",
    "typecheck": "tsc --noEmit",
    "test:unit": "vitest run --config vitest.config.ts",
    "test:integration": "vitest run --config vitest.config.ts --testNamePattern integration",
    "test:e2e": "pnpm exec start-server-and-test \"set E2E_PRERENDER=1&& pnpm dev --port 4417 --host 127.0.0.1\" http://127.0.0.1:4417 \"playwright test --config playwright.config.ts\"",
    "verify:content": "node ./scripts/verify-content.mjs",
    "verify:auto-publish": "node ./scripts/publish/fixture-checks.mjs",
    "verify:smoke": "node ./scripts/smoke/check-routes.mjs",
    "verify:lighthouse": "node ./scripts/run-lighthouse.cjs",
    "astro": "node ./scripts/astro-runner.cjs",
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "sync": "astro sync"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.7",
    "@axe-core/playwright": "^4.10.2",
    "@astrojs/cloudflare": "^13.1.1",
    "@astrojs/node": "^10.0.1",
    "@pagefind/default-ui": "^1.4.0",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/typography": "^0.5.19",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "@types/lodash.kebabcase": "^4.1.9",
    "@types/node": "^20.0.0",
    "astro": "^6.0.4",
    "eslint": "^8.56.0",
    "chrome-launcher": "^1.2.1",
    "lighthouse": "^12.8.2",
    "pagefind": "^1.4.0",
    "playwright": "^1.40.0",
    "start-server-and-test": "^2.1.2",
    "typescript": "^5.9.3",
    "vitest": "^0.34.0"
  },
  "dependencies": {
    "@astrojs/rss": "^4.0.17",
    "@astrojs/sitemap": "^3.7.1",
    "@tailwindcss/vite": "^4.2.1",
    "dayjs": "^1.11.20",
    "lodash.kebabcase": "^4.1.1",
    "remark-collapse": "^0.1.2",
    "remark-toc": "^9.0.0",
    "slugify": "^1.6.8",
    "tailwindcss": "^4.2.1"
  }
}
